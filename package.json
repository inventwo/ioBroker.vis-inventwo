{
  "name": "iobroker.vis-inventwo",
  "version": "3.3.5",
  "description": "Switch widgets for ioBroker.vis",
  "author": "jkvarel <jkvarel@inventwo.com>",
  "contributors": [
    "jkvarel <jkvarel@inventwo.com>",
    "skvarel <skvarel@inventwo.com>"
  ],
  "homepage": "https://github.com/inventwo/ioBroker.vis-inventwo",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "template",
    "Smart Home",
    "home automation",
    "inventwo",
    "vis"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inventwo/ioBroker.vis-inventwo.git"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.2.3",
    "minimist": "^1.2.5",
    "np": "^10.0.3"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.0.3"
  },
  "main": "main.js",
  "scripts": {
    "test:js": "mocha --opts test/mocha.custom.opts",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "lint": "eslint -c eslint.config.mjs .",
    "release-patch": "release-script patch --yes",
    "release-minor": "release-script minor --yes",
    "release-major": "release-script major --yes",
    "npm": "npm i"
  },
  "bugs": {
    "url": "https://github.com/inventwo/ioBroker.vis-inventwo/issues"
  },
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    ".git",
    ".idea",
    "node_modules/",
    "nbproject/",
    ".vs*/",
    "*.code-workspace",
    "Thumbs.db",
    "gulpfile.js",
    ".vscode",
    ".eslintrc.json",
    ".github",
    "test/",
    "travis/",
    ".travis.yml",
    "appveyor.yml",
    ".travis.yaml",
    "appveyor.yaml",
    "tsconfig.json",
    "tsconfig.*.json",
    ".eslintrc.json",
    ".eslintrc.js",
    "iobroker.*.tgz",
    "package-lock.json",
    "admin/i18n",
    "maintenance/**"
  ]
}
